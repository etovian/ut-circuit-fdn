<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20240309-1" author="gemini">
        <createTable tableName="event_template">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="location" type="VARCHAR(255)"/>
            <column name="congregation_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_event_template_congregation" referencedTableName="congregation" referencedColumnNames="id"/>
            </column>
            <column name="start_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="DATE"/>
            <column name="start_time" type="TIME">
                <constraints nullable="false"/>
            </column>
            <column name="duration_minutes" type="INT"/>
            <column name="recurrence_rule" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="event_occurrence">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="event_template_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_event_occurrence_template" referencedTableName="event_template" referencedColumnNames="id"/>
            </column>
            <column name="original_start_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="new_start_time" type="TIMESTAMP"/>
            <column name="is_cancelled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="override_name" type="VARCHAR(255)"/>
            <column name="override_description" type="TEXT"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
