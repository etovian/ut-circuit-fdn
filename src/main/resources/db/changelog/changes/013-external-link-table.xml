<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260312-1" author="gemini">
        <createTable tableName="congregation_external_link">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="congregation_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_cel_congregation" referencedTableName="congregation" referencedColumnNames="id"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="external_link_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="url" type="VARCHAR(1000)">
                <constraints nullable="false"/>
            </column>
            <column name="ordinal_value" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
