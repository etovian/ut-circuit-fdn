<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260310-1" author="gemini">
        <createTable tableName="person">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(50)"/>
            <column name="first_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="middle_name" type="VARCHAR(100)"/>
            <column name="last_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="suffix" type="VARCHAR(50)"/>
            <column name="date_of_birth" type="DATE"/>
            <column name="photo_file_name" type="VARCHAR(255)"/>
            <column name="biography" type="TEXT"/>
        </createTable>

        <createTable tableName="congregation_person">
            <column name="congregation_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" foreignKeyName="fk_cp_congregation" referencedTableName="congregation" referencedColumnNames="id"/>
            </column>
            <column name="person_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" foreignKeyName="fk_cp_person" referencedTableName="person" referencedColumnNames="id"/>
            </column>
            <column name="position" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
